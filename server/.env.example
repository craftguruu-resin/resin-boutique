# Copy to .env and fill in. Get token + phone number id from Meta for Developers → WhatsApp → API Setup.

PORT=3847
# If checkout is opened from Live Server / another port, set on checkout <html>: data-bill-api-port="3847" (match PORT above).

# JPEG preview (no token): POST /api/preview-bill-jpeg with body { "items": [...], "phone": "optional 10 digits" }

# Permanent access token (or system user token) with whatsapp_business_messaging
WHATSAPP_ACCESS_TOKEN=

# From WhatsApp → API Setup → "Phone number ID" (not your display number)
WHATSAPP_PHONE_NUMBER_ID=

# Optional. Default v21.0
# META_GRAPH_VERSION=v21.0

# CORS: production = comma-separated origins. Local dev: prefer * so Live Server / any port can call the API.
# A short list (e.g. only :5500) blocks the vendor login fetch if your editor uses :5501 or you open the site from another origin.
ALLOWED_ORIGIN=*

# Optional shared secret. If set, checkout AND vendor pages must send it: same value as data-bill-api-secret on
# checkout.html and vendor-*.html <html> (see comments in those files). Server middleware requires it for /api/vendor/* except /status and /categories.
# BILL_API_SECRET=

# Optional: extra entropy for guest email OTP hashes (defaults to a built-in string if unset).
# GUEST_OTP_PEPPER=

# --- Email OTP (6-digit sign-in / sign-up codes via nodemailer) ---
# If neither block below is set, OTPs are printed in the API server console instead of emailed.
#
# Option A — any SMTP provider (Hostinger, Zoho, SendGrid SMTP, Amazon SES SMTP, etc.):
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=orders@yourdomain.com
# SMTP_PASS=your-smtp-password
# MAIL_FROM="Craftguru <orders@yourdomain.com>"
#
# Option B — Gmail (use an App Password, not your normal password; Google Account → Security → App passwords):
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx
# MAIL_FROM="Craftguru <you@gmail.com>"

# Vendor /api/* management: leave unset for no login (default). Set to 1 to require Bearer token again.
# VENDOR_REQUIRE_AUTH=1

# Vendor dashboard login. With Postgres, `npm run db:migrate` syncs this user (insert or update password).
# If nammu/nammu fails, run: npm run db:vendor-login   (from server/ with DATABASE_URL set)
# Defaults if unset: username nammu, password nammu
# VENDOR_PORTAL_USER=studio
# VENDOR_PORTAL_PASSWORD=change-me

# Local testing only: enables POST /api/checkout-test-complete (“Pay without Razorpay” on checkout). Omit in production.
# ALLOW_TEST_CHECKOUT=1

# --- PostgreSQL (orders, guests, vendor sessions, catalog in DB) ---
# Local (after you create DB + user — see README or comments below):
# DATABASE_URL=postgresql://craftguru:yourpassword@127.0.0.1:5432/craftguru
# Hosted (Neon, Supabase, Railway, etc.): copy the "connection string" from their dashboard — same format.
# If DATABASE_URL is unset, the app uses file-based orders (server/data/orders.json) instead.
#
# Hostinger Web/Cloud does NOT include PostgreSQL. Use a free external DB and paste its URL here, e.g.:
#   https://neon.tech  or  https://supabase.com  → create project → copy "connection string"
# Or use Hostinger VPS and install PostgreSQL on the same VPS (DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/dbname).
